.email-signup
  margin-top: 1.5rem
  padding: 1rem 1.15rem
  border-radius: 0
  border: 1px solid $color-border
  background: $color-background
  color: $color-text
  position: relative
  overflow: hidden

  &--sidebar
    margin-top: 0

  &--inline,
  &--modal
    padding: 1.1rem 1.1rem 1rem

    .email-signup__title
      margin-bottom: .3rem
      color: $color-text
      letter-spacing: 0
      text-transform: none
      font-size: 1.05rem
      font-weight: 600

    .email-signup__description
      color: color-alpha($color-text, .72)
      font-size: .92rem
      line-height: 1.45

    .email-signup__form
      gap: .55rem
      margin-top: .75rem

    .email-signup__input
      border-radius: 0
      background: $color-background
      font-family: $font-family-body

    .email-signup__button
      border-radius: 0
      background: $color-text
      color: $color-background
      text-transform: none
      letter-spacing: 0
      box-shadow: none

      &:hover
        transform: none
        background: $color-accent-1
        box-shadow: none

      &:focus
        box-shadow: s('0 0 0 2px %s', color-alpha($color-link, .28))

  &--modal
    margin: 0
    width: calc(100vw - 2rem)
    max-width: 560px
    max-height: calc(100vh - 2rem)
    overflow: auto
    z-index: 2

  > *
    position: relative
    z-index: 1

  &__title
    margin-top: 0
    margin-bottom: .25rem
    color: $color-text
    letter-spacing: 0
    text-transform: none
    font-size: 1rem

  &__description
    margin-top: 0
    color: $color-meta
    font-size: .92rem

  &__form
    display: flex
    flex-wrap: wrap
    gap: .45rem
    margin-top: .65rem

  &__input
    flex: 1
    min-width: 180px
    padding: .45rem .6rem
    border-radius: 0
    border: 1px solid $color-border
    background: $color-background
    color: $color-text
    font-family: $font-family-body
    font-size: .95rem
    transition: border-color .2s ease, box-shadow .2s ease, background .2s ease

    &::placeholder
      color: color-alpha($color-text, .5)

    &:focus
      outline: none
      border-color: $color-accent-1
      box-shadow: none
      background: $color-background

  &__button
    padding: .5rem 1rem
    border-radius: 0
    border: none
    background: $color-text
    color: $color-background
    font-weight: 600
    letter-spacing: 0
    text-transform: none
    cursor: pointer
    box-shadow: none
    transition: background .2s ease

    &:hover
      transform: none
      box-shadow: none

    &:focus
      outline: none
      box-shadow: none

.email-signup-modal
  position: fixed
  inset: 0
  display: flex
  align-items: center
  justify-content: center
  z-index: 999
  padding: 1rem
  opacity: 0
  visibility: hidden
  pointer-events: none
  transition: opacity .2s ease

  &.is-visible
    opacity: 1
    visibility: visible
    pointer-events: auto

  &__backdrop
    position: absolute
    inset: 0
    background: rgba(#000, .42)
    backdrop-filter: blur(1px)

  &__close
    position: absolute
    top: .45rem
    right: .45rem
    width: 2rem
    height: 2rem
    border: none
    border-radius: 999px
    background: transparent
    color: color-alpha($color-text, .65)
    font-size: 1.2rem
    line-height: 1
    cursor: pointer
    z-index: 3

    &:hover
      background: color-alpha($color-border, .22)
      color: $color-text

    &:focus
      outline: none
      box-shadow: s('0 0 0 2px %s', color-alpha($color-link, .28))


.post-layout
  display: flex
  align-items: flex-start
  gap: 0
  position: relative

.post-sidebar
  flex: 0 0 auto
  width: 0
  margin: 0
  padding: 0
  position: sticky
  top: 4.5rem
  align-self: flex-start

.post-main
  flex: 1
  min-width: 0
  width: 100%

.post-sidebar .email-signup
  width: 150px
  transform: translateX(calc(-100% - 1.2rem))
  margin-top: 0
  margin-bottom: 0

@media (max-width: 540px)
  .email-signup
    padding: 1.5rem

    &__form
      flex-direction: column
      gap: .5rem

    &__button
      width: 100%

@media (max-width: 1040px)
  .post-layout
    flex-direction: column

  .post-sidebar
    position: static
    width: 100%
    margin-bottom: 1rem

  .post-sidebar .email-signup
    width: 100%
    transform: none
    margin-top: 1rem
