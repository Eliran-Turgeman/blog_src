<div id="archive">
  <% var archivePosts = page.posts || site.posts %>
  <ul class="post-list">
    <% if (archivePosts.length) { %>
      <% var year = 0 %>
      <% var change = false %>
      <% var field_sort = theme.archive.sort_updated ? 'updated' : 'date' %>
      <% archivePosts.sort(field_sort, 'desc').each(function(post) { %>
        <% var itemYear = date(post[field_sort], 'YYYY') - 0 %>
        <% change = year !== itemYear %>
        <% year = change ? itemYear : year %>
        <% if (change) { %>
          <li class="post-year"><h2><%= year %></h2></li>
        <% } %>
        <li class="post-item">
          <%- partial('_partial/post/date', { post: post, class_name: 'meta' }) %>
          <span><%- partial('_partial/post/title', { post: post, index: true, class_name: '' }) %></span>
        </li>
      <% }); %>
    <% } else { %>
      <li class="post-item">WIP</li>
    <% } %>
  </ul>
  <% if (page.posts && page.posts.length) { %>
    <%- partial('_partial/pagination') %>
  <% } %>
</div>
