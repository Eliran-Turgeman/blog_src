<%
  // ── centralised newsletter copy ──
  // Update these values in ONE place when your numbers change.
  var signupTitle       = (typeof title       !== 'undefined') ? title       : 'Get new posts by email';
  var signupDescription = (typeof description !== 'undefined') ? description : 'I break down how production systems actually get hacked — and how to defend them. One deep-dive at a time, for engineers who ship.';
  var signupButton      = (typeof buttonText  !== 'undefined') ? buttonText  : 'Subscribe';
  var signupSource      = (typeof source      !== 'undefined') ? source      : '';
  var signupAction      = 'https://app.kit.com/forms/9085244/subscriptions';
%>
<h3 class="email-signup__title"><%= signupTitle %></h3>
<p class="email-signup__description"><%= signupDescription %></p>
<form
  class="email-signup__form"
  action="<%= signupAction %>"
  method="POST"
  target="_blank"
  data-analytics-event="newsletter_form_submit"
  data-analytics-action="submit"
  data-analytics-location="email_signup"
  data-analytics-label="<%= signupButton %>"
>
  <input
    class="email-signup__input"
    type="email"
    name="email_address"
    placeholder="your@email.com"
    autocomplete="email"
    required
    data-analytics-event="newsletter_input_focus"
    data-analytics-action="focus"
    data-analytics-location="email_signup"
  >
  <% if (signupSource) { %>
    <input type="hidden" name="source" value="<%= signupSource %>">
  <% } %>
  <button class="email-signup__button" type="submit"
    data-analytics-event="newsletter_cta_click"
    data-analytics-action="click"
    data-analytics-location="email_signup"
    data-analytics-label="<%= signupButton %>"
  >
    <%= signupButton %>
  </button>
</form>
